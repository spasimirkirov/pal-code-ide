{
  "name": "pal-code",
  "productName": "Pal Code - AI Powered Code Editor",
  "version": "1.0.0",
  "description": "Pal Code is an AI IDE built for vibe coding, fast prototyping, and agent-assisted development workflows.",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "postinstall": "patch-package",
    "lint": "echo \"No linting configured\"",
    "eval:agent": "npx promptfoo eval -c evals/promptfooconfig.yaml",
    "mcp:filesystem": "npx @modelcontextprotocol/server-filesystem .",
    "mcp:memory": "npx @modelcontextprotocol/server-memory",
    "mcp:github": "npx @modelcontextprotocol/server-github"
  },
