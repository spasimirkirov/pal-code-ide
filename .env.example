# PAL IDE runtime environment example
#
# Copy this file to .env and set values as needed.
# Note: Electron reads these from process environment. If your launcher does not
# load .env automatically, export them in your shell before starting the app.

# ---- Llama network ----
PAL_LLAMA_HOST=127.0.0.1
PAL_LLAMA_PORT=1234

# ---- Llama binary selection ----
# auto   -> detect NVIDIA with nvidia-smi and prefer CUDA when available
# cuda   -> force CUDA package selection
# cpu    -> force CPU package selection
# vulkan -> force Vulkan package selection
PAL_LLAMA_BINARY_FLAVOR=auto

# ---- Optional explicit llama executable/model overrides ----
# Leave empty to use AppData/Roaming/PalCode managed runtime paths.
PAL_LLAMA_SERVER_PATH=
PAL_LLAMA_MODEL_PATH=

# Additional flags passed to llama-server executable.
# Example:
# PAL_LLAMA_EXTRA_ARGS=--ctx-size 16384 --n-gpu-layers 99
PAL_LLAMA_EXTRA_ARGS=

# ---- Hugging Face auth (optional) ----
# Set only if you need access to gated/private repositories.
# If invalid, PAL IDE will retry public access anonymously.
HF_TOKEN=
# HUGGINGFACE_TOKEN=
